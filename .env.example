# =============================================================================
# Captains Prediction Companion — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before starting the server.
#
#   cp .env.example .env
#
# Variables marked REQUIRED must be set. All others have safe defaults.
# =============================================================================


# -----------------------------------------------------------------------------
# AI / HERMES BACKBONE
# -----------------------------------------------------------------------------

# REQUIRED — Gemini API key used by the Hermes CLI when provider=gemini.
# Obtain one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Global AI provider for the alpha and oracle stages.
# Supported values: gemini
# Default: gemini
HERMES_PROVIDER=gemini

# Path or name of the Hermes CLI binary on your PATH.
# Override if the binary lives outside PATH or has a non-standard name.
# Default: hermes
HERMES_COMMAND=hermes

# Alias for HERMES_COMMAND — either variable is accepted; HERMES_COMMAND wins.
# HERMES_CLI=hermes

# Global Hermes model override. Applies to all Hermes invocations unless
# a stage-specific model variable is also set.
# Example: gemini-2.5-pro
HERMES_MODEL=

# Global Gemini model fallback. Used when no stage-specific model is set
# and HERMES_MODEL is also empty.
# Example: gemini-2.5-flash
GEMINI_MODEL=


# -----------------------------------------------------------------------------
# PIPELINE STAGE MODELS
# (each overrides the global fallback for its specific stage)
# -----------------------------------------------------------------------------

# Provider override for the alpha stage only.
# Inherits HERMES_PROVIDER when blank.
EVENT_MARKET_ALPHA_PROVIDER=gemini

# Model for the alpha (market analysis) stage.
# Default: gemini-2.5-flash
EVENT_MARKET_ALPHA_MODEL=gemini-2.5-flash

# Model for the implications stage.
# Falls back to HERMES_MODEL → GEMINI_MODEL when blank.
IMPLICATIONS_MODEL=

# Model for the validation stage.
# Falls back to HERMES_MODEL → GEMINI_MODEL when blank.
VALIDATION_MODEL=


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# HTTP port the MCP server listens on.
# Default: 3000
PORT=3000

# Human-readable app identity string (shown in logs and health endpoints).
APP_NAME=Captains Prediction Companion

# App version string (shown in health endpoints).
APP_VERSION=1.0.0


# -----------------------------------------------------------------------------
# STORAGE / STATE FILES
# (paths are relative to the project root unless absolute)
# -----------------------------------------------------------------------------

# Path to the notes JSON store used by note MCP tools.
# Default: ./data/notes.json
APP_DATA_FILE=./data/notes.json

# General app state file (persisted across restarts).
# Default: ./data/captainlabs-state.json
CAPTAINLABS_STATE_FILE=./data/captainlabs-state.json

# Pipeline run-state file (tracks in-flight processing).
# Default: ./data/pipeline-state.json
PIPELINE_STATE_FILE=./data/pipeline-state.json

# Pipeline card-output file (final results written here after each run).
# Default: ./data/pipeline-card-outputs.json
PIPELINE_OUTPUT_FILE=./data/pipeline-card-outputs.json


# -----------------------------------------------------------------------------
# PIPELINE SEEDING
# -----------------------------------------------------------------------------

# Comma- or newline-separated list of Kalshi event/market URLs to pre-seed
# the pipeline on startup. Leave blank to rely solely on calendar seeding
# or manual tool calls.
# Example: https://kalshi.com/events/PRES-2026,https://kalshi.com/events/ECON-CPI
PIPELINE_SEED_URLS=

# Kalshi calendar URL used for automatic event discovery and pipeline seeding.
# Leave blank to disable calendar auto-seeding.
# Example: https://kalshi.com/calendar
PIPELINE_CALENDAR_URL=

# Maximum number of calendar events to load during auto-seed.
# Default: 50
PIPELINE_CALENDAR_LIMIT=50


# -----------------------------------------------------------------------------
# KALSHI API
# -----------------------------------------------------------------------------

# Override for the Kalshi REST API base URL.
# Only change this to point at a staging/sandbox environment.
# Default: https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2


# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------

# Set to "true" to enable the note-storage MCP tools:
#   remember_note, list_notes, search_notes, delete_note
# Default: false
ENABLE_NOTE_TOOLS=false
