# Captains Prediction Companion
# Copy to .env and fill in your values.

# Required: Hermes auth configured for the alpha stage's Gemini provider
# No OpenRouter API key is needed for alpha transport.
HERMES_PROVIDER=gemini

# Optional: default models and alpha overrides
IMPLICATIONS_MODEL=
VALIDATION_MODEL=
EVENT_MARKET_ALPHA_PROVIDER=gemini
EVENT_MARKET_ALPHA_MODEL=gemini-2.5-flash
GEMINI_MODEL=

# App identity (override if needed)
APP_NAME=Captains Prediction Companion
APP_VERSION=1.0.0

# Server port (default: 3000)
PORT=3000

# Note tools: set to true to enable remember_note / list_notes / search_notes / delete_note
ENABLE_NOTE_TOOLS=false

# Note storage file path
APP_DATA_FILE=./data/notes.json
