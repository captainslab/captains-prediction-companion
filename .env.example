# Captains Prediction Companion
# Copy to .env and fill in your values.

# Required: model provider key (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Optional: model to use (defaults to openrouter/free)
OPENROUTER_MODEL=openrouter/free

# App identity (override if needed)
APP_NAME=Captains Prediction Companion
APP_VERSION=1.0.0

# Server port (default: 3000)
PORT=3000

# Note tools: set to true to enable remember_note / list_notes / search_notes / delete_note
ENABLE_NOTE_TOOLS=false

# Note storage file path
APP_DATA_FILE=./data/notes.json
